{
  "version": 2,
  "framework": "vite",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/(manifest.json|manifest.webmanifest|sw.js|workbox-.*.js|registerSW.js|.*\\.png|.*\\.svg|.*\\.ico)",
      "destination": "/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
